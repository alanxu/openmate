# Copy this file to `.env` and fill in your key.
#
# OpenMate's Claude/Anthropic adapter targets MiniMax's Anthropic-compatible
# endpoint by default, so ANTHROPIC_API_KEY holds a MiniMax API key.

# Your MiniMax API key (used as the Anthropic key).
ANTHROPIC_API_KEY=sk-your-minimax-key-here

# MiniMax's Anthropic-compatible endpoint. Point this elsewhere to use a
# different provider (e.g. https://api.anthropic.com for real Claude).
ANTHROPIC_BASE_URL=https://api.minimax.io/anthropic

# Model name. MiniMax options include: MiniMax-M2, MiniMax-M2.5, MiniMax-M3.
OPENMATE_MODEL=MiniMax-M2

# --- Gmail MCP server (optional) ------------------------------------------
# Two real-server options exist; pick one.

# Option A — LOCAL real server (servers/gmail/server.py). Same `gmail_*` tool
# names as the offline fake, so the email skills work unchanged. See
# servers/gmail/README.md for the one-time token bootstrap.
# GOOGLE_CLIENT_ID=your-oauth-client-id
# GOOGLE_CLIENT_SECRET=your-oauth-client-secret
# TOKEN_PATH=~/.config/openmate/gmail/token.json

# Option B — OPEN-SOURCE npm server (examples/email_assistant_live.py).
# Auto-handles the OAuth flow; credentials live in ~/.gmail-mcp/, NOT in env.
# Bootstrap:
#   1. drop your OAuth client JSON at ~/.gmail-mcp/gcp-oauth.keys.json
#      (Desktop-app or Web-app; for Web-app register
#       http://localhost:3000/oauth2callback as a redirect URI)
#   2. npx -y @gongrzhe/server-gmail-autoauth-mcp auth
# The first run of the example will reuse ~/.gmail-mcp/credentials.json.
# Note: the upstream package was archived 2026-03-03; still works, no
# upstream fixes.
